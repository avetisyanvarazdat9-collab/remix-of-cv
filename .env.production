# Production builds must NOT bake in the Lovable sandbox Supabase project.
# Leave these empty so Vite does not inline the dev fallback values from .env
# into the production bundle. On Vercel (or any host) set the real values as
# environment variables in the project settings — they will override these
# empty strings at build time.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
